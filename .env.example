# 通义千问 DashScope API Key，去 https://dashscope.console.aliyun.com/ 申请
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 一般不用改，DashScope 的 OpenAI 兼容模式endpoint
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名，可选 qwen-max / qwen-plus / qwen-turbo，按效果和成本权衡
DASHSCOPE_MODEL=qwen-max

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

SERVICE_PORT=8002
LOG_LEVEL=INFO
